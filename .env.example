# Multicoders Environment Configuration

# LLM Providers (Required for real execution)
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here

# Storage Configuration
DATABASE_URL=sqlite:///multicoders.db
WORKDIR_ROOT=/tmp/multicoders-runs

# Parrot Integration
PARROT_LOG_LEVEL=INFO
PARROT_STORAGE_BACKEND=sqlite
